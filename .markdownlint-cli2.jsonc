{
  // Relaxed markdown rules for prose-heavy skill docs.
  "config": {
    "default": true,
    "MD013": false, // line length — prose and tables run long on purpose
    "MD033": false, // inline HTML — the README uses HTML comment catalog markers
    "MD041": false  // first line need not be a top-level heading
  },
  "ignores": ["node_modules/**", "skills/**", ".github/**"]
}
